{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Venderctl: Dynamic",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/cmd/venderctl/main.go",
            "env": {
                "app_ver": "debug"
            },
            "buildFlags": "-ldflags='-X main.BuildVersion=debug'",
            "args": [
                "-config",
                "/etc/venderctl/dev.hcl",
                "${input:command}"
            ]
        }
    ],
    "inputs": [
        {
            "id": "command",
            "type": "pickString",
            "description": "Что запускаем?",
            "options": [
                "version",
                "sponge",
                "tax",
                "telegram",
                "control",
                "web"
            ],
            "default": "web"
        }
        // ,
        // {
        //     "id": "configFile",
        //     "type": "pickString",
        //     "description": "Какой конфиг?",
        //     "options": [
        //         "version",
