{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Venderctl: Dynamic",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/cmd/venderctl/main.go",
            "env": { "app_ver": "debug" },
            "buildFlags": "-ldflags='-X main.BuildVersion=debug'",
            "args": [
                "-config",
                "/etc/venderctl/dev.hcl",
                // "/etc/venderctl/prod.hcl",
                "${input:command}"
            ]
        },    
        {
            "name": "Firefox: Web Port",
            "type": "firefox",
            "request": "launch",
            "reAttach": true,
            "url": "http://localhost:8086",
            // "url": "https://am.inkcat.net",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Venderctl: Full Web (Go + Firefox)",
            "configurations": [
                "Venderctl: Dynamic",
                "Firefox: Web Port"
            ]
        }
    ],
    "inputs": [
        {
            "id": "command",
            "type": "pickString",
            "description": "Что запускаем?",
            "options": [
                "telegram", "web", "control", "version", "sponge", "tax"
            ],
            // "default": "web"
        }
    ]
}
